{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "stronghold:default",
    "notification:default",
    "notification:allow-is-permission-granted",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**/*" }]
    }
  ]
}
