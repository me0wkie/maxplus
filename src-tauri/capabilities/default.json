{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "store:default",
    "dialog:default",
    "fs:default",
    "fs:allow-download-write",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://**" }]
    },
    {
      "identifier": "fs:allow-read",
      "allow": [{ "path": "**/*" }]
    }
  ]
}
